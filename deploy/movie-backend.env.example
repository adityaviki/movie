# /etc/movie-backend.env  (mode 0640, root:ubuntu)
# Loaded by movie-backend.service.

NODE_ENV=production
PORT=3001

# From provision-db.sh output:
DATABASE_URL=postgres://movie:REPLACE_ME@127.0.0.1:5432/movie_manager

# Generate fresh, strong values:
#   openssl rand -hex 32
JWT_SECRET=REPLACE_ME_OPENSSL_RAND_HEX_32
COOKIE_SECRET=REPLACE_ME_OPENSSL_RAND_HEX_32

# Public origin (used by CORS and the auth cookie). Must match the URL users hit.
FRONTEND_URL=https://movies.adityaviki.com

# For seeding the first admin user via `pnpm db:backfill` (delete after first run).
# SEED_USER_EMAIL=you@example.com
# SEED_USER_USERNAME=admin
# SEED_USER_PASSWORD=change-me-strong
